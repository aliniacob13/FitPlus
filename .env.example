# ── Database ──────────────────────────────────────────────
POSTGRES_USER=fitplus
POSTGRES_PASSWORD=fitplus_secret
POSTGRES_DB=fitplus_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed automatically by the app from the values above.
# DATABASE_URL=postgresql+asyncpg://fitplus:fitplus_secret@localhost:5432/fitplus_db

# ── FastAPI ───────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
DEBUG=true
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── AI / LLM ──────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Vision model for Phase 4 Plate Coach — must support image input.
# OpenAI options: gpt-4o, gpt-4o-mini
# Anthropic options: claude-3-5-sonnet-20241022
VISION_LLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhooks cannot reach http://localhost unless you use Stripe CLI: stripe listen --forward-to http://localhost:PORT/api/v1/payments/webhook
# For local/dev the app calls POST /payments/checkout/confirm-session after checkout so subscriptions are still saved.

# Checkout success/cancel URLs (Stripe replaces {CHECKOUT_SESSION_ID} in success URL).
STRIPE_CHECKOUT_SUCCESS_URL=https://example.com/fitplus/payment-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://example.com/fitplus/payment-cancel

# Gyms from Google Places usually have no pricing_plans in DB. When DEBUG=true, the API uses demo plans.
# Set SUBSCRIPTION_FALLBACK_PRICING=true if DEBUG=false but you still want placeholder plans (tests only).
SUBSCRIPTION_FALLBACK_PRICING=false

# Optional limits for POST /gyms/{id}/pricing/import-from-url (HTML fetch).
# GYM_PRICING_IMPORT_MAX_BYTES=1500000
# GYM_PRICING_IMPORT_MAX_TEXT_CHARS=14000

# ── Google Maps / Places ──────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Nutrition / Food Search (Phase 2) ────────────────────
# Free key at https://fdc.nal.usda.gov/api-key-signup
# Omit or leave empty to use DEMO_KEY (30 req/hr, 50 req/day limit).
USDA_API_KEY=

# ── Dev seeding (Gym demo data) ───────────────────────────
SEED_ENABLED=false
SEED_TOKEN=

# ── pgAdmin (Docker) ──────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@fitplus.com
PGADMIN_DEFAULT_PASSWORD=admin123
