# ── Database ──────────────────────────────────────────────
POSTGRES_USER=fitplus
POSTGRES_PASSWORD=fitplus_secret
POSTGRES_DB=fitplus_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed automatically by the app from the values above.
# DATABASE_URL=postgresql+asyncpg://fitplus:fitplus_secret@localhost:5432/fitplus_db

# ── FastAPI ───────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
DEBUG=true
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── AI / LLM ──────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Dev seeding (Gym demo data) ───────────────────────────
SEED_ENABLED=false
SEED_TOKEN=
