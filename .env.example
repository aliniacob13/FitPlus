# ── Database ──────────────────────────────────────────────
POSTGRES_USER=fitplus
POSTGRES_PASSWORD=fitplus_secret
POSTGRES_DB=fitplus_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed automatically by the app from the values above.
# DATABASE_URL=postgresql+asyncpg://fitplus:fitplus_secret@localhost:5432/fitplus_db

# ── FastAPI ───────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string
DEBUG=true
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── AI / LLM ──────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Google Maps / Places ──────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Nutrition / Food Search (Phase 2) ────────────────────
# Free key at https://fdc.nal.usda.gov/api-key-signup
# Omit or leave empty to use DEMO_KEY (30 req/hr, 50 req/day limit).
USDA_API_KEY=

# ── Dev seeding (Gym demo data) ───────────────────────────
SEED_ENABLED=false
SEED_TOKEN=

# ── pgAdmin (Docker) ──────────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@fitplus.com
PGADMIN_DEFAULT_PASSWORD=admin123
